{
  "name": "Cognitive ESM Lab (JS + Phaser)",
  "image": "denoland/deno:latest",
  "forwardPorts": [8080], 
  "portsAttributes": {
    "8080": {
      "label": "Phaser Stage",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "deno.enable": true,
        "deno.lint": true
      }
    }
  },
  "postCreateCommand": "deno jupyter --install",
  "postStartCommand": "deno cache jsr:@std/http/file-server"
}