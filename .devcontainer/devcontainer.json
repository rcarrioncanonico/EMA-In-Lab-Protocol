{
  "name": "Cognitive ESM Lab (JS + Phaser)",
  "image": "denoland/deno:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "deno.enable": true,
        "deno.lint": true
      }
    }
  },
  "postCreateCommand": "deno jupyter --install", "postCreateCommand": "deno run --allow-net --allow-read https://deno.land/std@0.190.0/http/file_server.ts --port 8080 &"
  
}