%%{init: {"theme": "default", "themeVariables": {"fontSize": "14px"}}}%%
flowchart TD

  %% ── Installation layer ──────────────────────────────────────────
  subgraph INSTALL["Step 1 · Install once on your Windows PC"]
    direction LR
    MC["**Miniconda**\nPackage & environment\nmanager\n(Anaconda Prompt)"]
    PS["**PsychoPy Standalone**\nGUI Builder for\ndesigning experiments\n(optional for Level 1–2)"]
  end

  %% ── Environment layer ───────────────────────────────────────────
  subgraph ENV["Step 2 · Create the Python environment"]
    direction LR
    YML["**psychopy_env.yml**\nBlueprint file\n(downloaded from GitHub)"]
    ENV2["**psychopy_env**\nConda environment\nPython 3.10 + PsychoPy\n+ all dependencies"]
  end

  %% ── Coding layer ────────────────────────────────────────────────
  subgraph CODE["Step 3 · Write & edit experiment code"]
    direction LR
    VSC["**VS Code**\nCode editor\n(interpreter set to psychopy_env)"]
    PY["**Python scripts**\n.py task files\n(e.g. nBackAlpha3.py)"]
  end

  %% ── Deployment layer ────────────────────────────────────────────
  subgraph DEPLOY["Step 4 · Deploy & collect data"]
    direction TB
    PAV["**Pavlovia**\nHosts the web version\nof your experiment\n(uses PsychoJS)"]
    MPATH["**m-Path**\nSends notifications\nto participants\nLinks them to Pavlovia"]
    LAB["**Local Lab PC**\nRuns task natively\nin PsychoPy\n(controlled setting)"]
  end

  %% ── Flow arrows ─────────────────────────────────────────────────
  MC -->|"conda env create -f"| YML
  YML -->|"builds"| ENV2
  ENV2 -->|"interpreter selected in"| VSC
  VSC -->|"edits / runs"| PY
  PY -->|"upload via Git"| PAV
  PAV -->|"linked in"| MPATH
  PY -->|"run locally"| LAB

  %% ── Level annotations ───────────────────────────────────────────
  LAB -. "Level 1:\nCollect single-timepoint\nlab data" .- L1(( ))
  PAV -. "Level 2:\nCollect EMA data\nvia smartphone" .- L2(( ))
  PY  -. "Level 3:\nAdjust / modify\ntask code" .- L3(( ))

  %% ── Styles ──────────────────────────────────────────────────────
  classDef tool    fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f,font-weight:bold
  classDef env     fill:#dcfce7,stroke:#22c55e,color:#14532d,font-weight:bold
  classDef deploy  fill:#fef9c3,stroke:#eab308,color:#713f12,font-weight:bold
  classDef level   fill:#f3f4f6,stroke:#9ca3af,color:#374151,font-size:11px
  classDef hidden  fill:transparent,stroke:transparent,color:transparent

  class MC,PS,VSC tool
  class YML,ENV2 env
  class PAV,MPATH,LAB deploy
  class L1,L2,L3 hidden
